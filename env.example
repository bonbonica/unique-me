# Database
POSTGRES_URL=postgresql://dev_user:dev_password@localhost:5432/postgres_dev

# Authentication - Better Auth
# Generate key using https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=qtD4Ssa0t5jY7ewALgai97sKhAtn7Ysc
# Base URL for OAuth callbacks (defaults to NEXT_PUBLIC_APP_URL if unset)
BETTER_AUTH_URL=http://localhost:3000

# Anthropic (REQUIRED) - powers website analysis and post generation.
# Get your API key from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Firecrawl (Required in production, optional in dev) - scrapes user-supplied
# business websites during onboarding. Get your key from https://firecrawl.dev
FIRECRAWL_API_KEY=

# OpenAI (Required in production, optional in dev) - reserved for Phase 3 image
# generation. Get your key from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Encryption key (Required in production, optional in dev) - used to encrypt
# OAuth tokens stored on connected_accounts (Phase 5+). Must be a 32-byte
# base64 string (44 chars including padding `=`).
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY=

# Optional - for vector search only
OPENAI_EMBEDDING_MODEL="text-embedding-3-large"

# App URL (for production deployments)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Resend (Required in production, optional in dev) - sends verification and
# password-reset emails from noreply@uniqueme.app. Get your key from
# https://resend.com/api-keys. When unset in dev the email helper logs links
# to the server console so the verification flow still works locally.
RESEND_API_KEY=

# File storage (optional - if app required file uploads)
BLOB_READ_WRITE_TOKEN=

# Google OAuth (OPTIONAL) — when both are set, the login page shows a
# "Continue with Google" button above the email/password form. When either is
# missing the app falls back to email/password only. Create credentials at
# https://console.cloud.google.com and configure OAuth consent.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Polar payment processing
# Get these from: https://sandbox.polar.sh/dashboard (sandbox) or https://polar.sh/dashboard (production)
POLAR_WEBHOOK_SECRET=polar_
POLAR_ACCESS_TOKEN=polar_
